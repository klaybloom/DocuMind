# 复制为 application-local.yml 后填写本机 MySQL 和 Redis 连接信息。
spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/documind?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: documind
    password: <从密钥管理或环境变量提供>
  data:
    redis:
      host: 127.0.0.1
      port: 6379
      password: <如 Redis 未设置密码则留空>

app:
  vector-store:
    qdrant:
      host: 127.0.0.1
      grpc-port: 6334
      health-url: http://127.0.0.1:6333/healthz
      collection: documind-segments
      api-key: <未启用认证时留空>
      use-tls: false
      dimension: 384
  deepseek:
    api-key: <从密钥管理或环境变量提供>
  security:
    admin-password: <从密钥管理或环境变量提供>
